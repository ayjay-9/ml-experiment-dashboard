.env
.env.*
!.env.example

# ── Django ───────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# ── Celery ───────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Docker ───────────────────────────────────────────────
.docker/

# ── Uploaded datasets (user data, not source code) ───────
uploads/
datasets/

# ── ML artefacts ─────────────────────────────────────────
*.pkl
*.joblib
*.h5
*.model
models/saved/
experiments/outputs/

# ── Testing & coverage ───────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── MyPy / type checking ─────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Jupyter (if you prototype in notebooks) ──────────────
.ipynb_checkpoints/
*.ipynb

# ── OS junk ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ─────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ── Node (if using a JS build step) ──────────────────────
node_modules/
npm-debug.log*

# ── Static files collected by Django ─────────────────────
staticfiles/
static_root/